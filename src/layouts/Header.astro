---
import config from "../config/config.json";
import menu from "../config/menu.json";

const { main } = menu;
const { settings } = config;
const currentPath = Astro.url.pathname;
---

<header class={`header z-30 ${settings.sticky_header ? "sticky top-0" : ""}`}>
  <nav class="navbar container">
    <!-- Hidden spacer block for desktop layout balance -->
    <div class="order-0 hidden lg:block w-[160px]"></div>

    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      for="nav-toggle"
      class="order-3 cursor-pointer flex items-center lg:hidden text-dark lg:order-1"
    >
      <svg id="show-button" class="h-6 fill-current block" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
      <svg id="hide-button" class="h-6 fill-current hidden" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"
        ></polygon>
      </svg>
    </label>

    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full pb-6 text-center lg:order-1 lg:flex lg:w-auto lg:space-x-2 lg:pb-0 lg:mx-auto"
    >
      {main.map((item: { name: string; url: string }) => (
        <li class="nav-item">
          <a
            href={item.url}
            class={`nav-link block active ${
              currentPath === `${item.url}/` || currentPath === item.url
                ? "text-primary"
                : ""
            }`}
          >
            {item.name}
          </a>
        </li>
      ))}
      <li class="mt-4 inline-block lg:hidden">
        <a
          class="btn btn-outline-primary btn-sm"
          href={settings.navigation_button.link}
        >
          {settings.navigation_button.label}
        </a>
      </li>
    </ul>

    <div class="order-1 ml-auto flex items-center md:order-2 lg:ml-0">
      <button
        class="border-border text-dark hover:text-primary mr-5 inline-block border-r pr-5 text-xl"
        aria-label="search"
        data-search-trigger
      >
        <svg viewBox="0 0 512 512" height="16" width="16" fill="currentColor">
          <path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0s208 93.1 208 208zM208 352a144 144 0 100-288 144 144 0 100 288z" />
        </svg>
      </button>

      <button
        class="border-border text-dark hover:text-primary mr-5 inline-block border-r pr-5 text-xl"
        aria-label="phone"
      >
        <a href="tel:+44-7480-488-209">
          <svg viewBox="0 0 512 512" height="16" width="16" fill="currentColor">
            <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z" />
          </svg>
        </a>
      </button>

      <a
        class="btn btn-outline-primary btn-sm hidden lg:inline-block"
        href={settings.navigation_button.link}
      >
        {settings.navigation_button.label}
      </a>
    </div>
  </nav>
</header>

<script>
  // Mobile menu: close on click outside
  document.addEventListener("DOMContentLoaded", () => {
    const checkbox = document.getElementById("nav-toggle") as HTMLInputElement;
    document.addEventListener("mousedown", () => {
      if (checkbox?.checked) {
        setTimeout(() => { checkbox.checked = false; }, 100);
      }
    });
  });
</script>
