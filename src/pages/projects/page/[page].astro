---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../layouts/PageHeader.astro";
import ProjectCard from "../../../layouts/ProjectCard.astro";
import Pagination from "../../../layouts/Pagination.astro";
import { getCollection, getEntry } from "astro:content";
import config from "../../../config/config.json";

export async function getStaticPaths() {
  const { pagination } = config.settings;
  const allProjects = (await getCollection("projects"))
    .filter((p) => p.id !== "_index" && !p.data.draft);
  const totalPages = Math.ceil(allProjects.length / pagination);

  const paths = [];
  for (let i = 2; i <= totalPages; i++) {
    paths.push({ params: { page: String(i) } });
  }
  return paths;
}

const { pagination } = config.settings;
const pageNum = Number(Astro.params.page);
const postIndex = await getEntry("projects", "_index");

const allProjects = (await getCollection("projects"))
  .filter((p) => p.id !== "_index" && !p.data.draft)
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
    const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
    return dateB - dateA;
  });

const totalPages = Math.ceil(allProjects.length / pagination);
const indexOfLastPost = pageNum * pagination;
const indexOfFirstPost = indexOfLastPost - pagination;
const currentPosts = allProjects.slice(indexOfFirstPost, indexOfLastPost);
---

<BaseLayout
  title={`${postIndex?.data.title} - Page ${pageNum}`}
  description={postIndex?.data.description}
>
  <PageHeader heading={postIndex?.data.heading || "Projects"} />
  <section class="section">
    <div class="container">
      <div class="row gx-5">
        <div>
          <div class="row">
            {currentPosts.map((post) => (
              <div class="mb-14 md:col-6">
                <ProjectCard
                  heading={post.data.heading}
                  image={post.data.image}
                  slug={post.id}
                />
              </div>
            ))}
          </div>
          <Pagination section="projects" currentPage={pageNum} totalPages={totalPages} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
