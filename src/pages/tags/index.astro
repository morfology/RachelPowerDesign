---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../layouts/PageHeader.astro";
import { getCollection, getEntry } from "astro:content";
import { slugify, humanize } from "../../lib/utils/textConverter";

const page = await getEntry("tags", "_index");

const allProjects = (await getCollection("projects"))
  .filter((p) => p.id !== "_index" && !p.data.draft);

const tagMap = new Map<string, number>();
for (const project of allProjects) {
  for (const tag of project.data.tags || []) {
    const key = slugify(tag.toLowerCase());
    tagMap.set(key, (tagMap.get(key) ?? 0) + 1);
  }
}
const countedItems = Array.from(tagMap.entries()).map(([name, count]) => ({ name, count }));
---

<BaseLayout title={page?.data.title} description={page?.data.description}>
  <PageHeader heading="Tags" />
  <section class="section">
    <div class="container text-center">
      <ul>
        {countedItems.map(({ name: tag, count }) => (
          <li class="m-3 inline-block">
            <a
              href={`/tags/${tag}`}
              class="block rounded bg-theme-light px-4 py-2 text-xl text-dark"
            >
              {humanize(tag)}
              <span class="ml-2 rounded bg-body px-2">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
