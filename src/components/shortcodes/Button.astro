---
interface Props {
  label: string;
  link: string;
  style?: string;
  rel?: string;
}

const { label, link, style, rel } = Astro.props;
const relAttr = `noopener noreferrer ${rel ? (rel === 'follow' ? '' : rel) : 'nofollow'}`;
const btnClass = style === 'outline' ? 'btn-outline-primary' : 'btn-primary';
---

<a
  href={link}
  target="_blank"
  rel={relAttr}
  class={`btn mb-4 me-4 no-underline hover:text-white ${btnClass}`}
>
  {label}
</a>
