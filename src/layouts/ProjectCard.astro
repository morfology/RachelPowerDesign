---
interface Props {
  heading: string;
  image?: string;
  slug: string;
}

const { heading, image, slug } = Astro.props;

const generateAltText = (): string => {
  if (!heading) return "Interior design project";
  const lowerHeading = heading.toLowerCase();
  if (lowerHeading.includes("design") || lowerHeading.includes("renovation") || lowerHeading.includes("refurbishment")) {
    return heading;
  }
  return `${heading} - Interior design project`;
};
---

<a href={`/projects/${slug}`}>
  <div class="relative max-w-xl mx-auto mt-20">
    {image && (
      <img
        src={image}
        alt={generateAltText()}
        width="900"
        height="600"
        class="rounded-md object-cover"
        loading="lazy"
        decoding="async"
      />
    )}
    <div class="absolute inset-0 bg-gray-700 opacity-30 rounded-md"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h2 class="text-white text-3xl font-bold text-center px-4">{heading}</h2>
    </div>
  </div>
</a>
